# =============================================================================
# Aqua: Universal Telemetry Platform
# =============================================================================
#
# Only host-level knobs live in this file. The actual pipelines you want to
# scrape (URLs, polling intervals, separators, etc.) live in pipelines.toml.
#
# See pipelines.toml for the full pipeline schema and examples covering:
#   - GET vs POST endpoints
#   - Custom body / content-type for POST
#   - Custom separators (e.g. ["xxx", "\n", "\t"], or ["|", ","], or just ["\n"])
#   - Per-pipeline label blocklist
# =============================================================================

# Host port mappings
AQUA_PORT=9090       # collector /metrics + /snapshot
PROM_PORT=9091       # Prometheus UI
GRAFANA_PORT=3005    # Grafana UI
MCP_PORT=5000        # MCP Toolbox HTTP server (/mcp)

# Grafana admin password
GRAFANA_PASSWORD=admin

# Prometheus retention (e.g. 7d, 30d, 1y)
PROM_RETENTION=10y

# Rust log level for the collector: trace, debug, info, warn, error
RUST_LOG=info
