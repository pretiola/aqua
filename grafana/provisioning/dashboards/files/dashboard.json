        "options": [],
        "query": { "qryType": 1, "query": "label_values(aqua_metric{pipeline=~\"$pipeline\"}, name)", "refId": "PrometheusVariableQueryEditor-VariableQuery" },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
